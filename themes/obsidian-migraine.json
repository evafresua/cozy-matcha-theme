  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#a4b5a9",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage"],
      "settings": {
        "foreground": "#aebf9c"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#b1ccad"
      }
    },
    {
      "scope": ["string"],
      "settings": {
        "foreground": "#8da38c"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language", "constant.character", "constant.other"],
      "settings": {
        "foreground": "#afc9ab"
      }
    },
    {
      "scope": ["variable"],
      "settings": {
        "foreground": "#d4e0d7"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type.primitive", "support.class"],
      "settings": {
        "foreground": "#799478"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#8da38c",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.heading.2"],
      "settings": {
        "foreground": "#aebf9c"
      }
    },
    {
      "scope": ["markup.heading.3"],
      "settings": {
        "foreground": "#799478"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    }
  ]
}